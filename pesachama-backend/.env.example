# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# M-Pesa / Daraja
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-stk-passkey
MPESA_BUSINESS_SHORTCODE=174379
MPESA_B2C_SHORTCODE=your-b2c-shortcode
MPESA_INITIATOR_NAME=your-initiator-name
MPESA_ENV=sandbox
MPESA_SECURITY_CREDENTIAL=your-security-credential
MPESA_MSHWARI_PASSKEY=your-mshwari-passkey

# KCB Buni
KCB_BUNI_BASE_URL=https://sandbox.buni.kcbgroup.com
KCB_BUNI_TOKEN_URL=https://accounts.buni.kcbgroup.com/oauth2/token
KCB_BUNI_DEVPORTAL_URL=https://sandbox.buni.kcbgroup.com/devportal
KCB_BUNI_CONSUMER_KEY=your-kcb-buni-consumer-key
KCB_BUNI_CONSUMER_SECRET=your-kcb-buni-consumer-secret
KCB_BUNI_ACCESS_TOKEN=your-kcb-buni-access-token

# Optional KPLC / utility payment metadata
KPLC_BILLER_CODE=your-kplc-biller-code
KPLC_ACCOUNT_REFERENCE=your-kplc-account-reference

# Email Configuration (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_FROM=info@example.com
